    {
      "name": "SEC EDGAR Full-Text Search",
      "base_url": "https://efts.sec.gov/LATEST",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, 10 requests/second, User-Agent with email required",
      "key_env_var": null,
      "docs_url": "https://efts.sec.gov/LATEST/search-index?q=&dateRange=custom",
      "endpoints": [
        {
          "path": "/search-index?q={query}&dateRange=custom&startdt={start}&enddt={end}",
          "method": "GET",
          "desc": "Full-text search of SEC filings (10-K, 10-Q, 8-K, etc.)",
          "example": "curl -H 'User-Agent: api-catalog admin@example.com' 'https://efts.sec.gov/LATEST/search-index?q=artificial+intelligence&dateRange=custom&startdt=2025-01-01&enddt=2025-12-31'"
        },
        {
          "path": "/search-index?q={query}&forms=10-K",
          "method": "GET",
          "desc": "Search filings filtered by form type",
          "example": "curl -H 'User-Agent: api-catalog admin@example.com' 'https://efts.sec.gov/LATEST/search-index?q=revenue+decline&forms=10-K'"
        }
      ]
    },
