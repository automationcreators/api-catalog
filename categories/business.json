        },
        {
          "path": "/v21/api.json?KEY={key}&LOOKUP={domain}",
          "method": "GET",
          "desc": "Detailed technology profile including analytics, CDN, frameworks, and CMS",
          "example": "curl 'https://api.builtwith.com/v21/api.json?KEY=$BUILTWITH_API_KEY&LOOKUP=github.com'"
        }
      ]
    },
    {
      "name": "WhoisXML API",
      "base_url": "https://www.whoisxmlapi.com/whoisserver",
      "auth": "apiKey",
      "auth_param": "apiKey",
      "auth_location": "query",
      "free_tier": "500 queries/month on free tier",
