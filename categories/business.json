      "name": "Google Places API",
      "base_url": "https://maps.googleapis.com/maps/api/place",
      "auth": "apiKey",
      "auth_param": "key",
      "auth_location": "query",
      "free_tier": "$200/month free credit (~5,000 text searches), requires billing account",
