      "docs_url": "https://www.glassdoor.com/developer/index.htm",
      "endpoints": [
        {
          "path": "/api.htm?t.p={partner_id}&t.k={key}&action=employers&q={company}",
          "method": "GET",
          "desc": "Search employers by name to get ratings and review counts",
          "example": "curl 'https://www.glassdoor.com/api/api.htm?t.p=PARTNER_ID&t.k=PARTNER_KEY&action=employers&q=Google&format=json'"
        }
      ]
