    {
      "name": "SEC EDGAR Company Search",
      "base_url": "https://efts.sec.gov/LATEST",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, must include User-Agent header with contact email. 10 requests/second",
      "key_env_var": null,
      "docs_url": "https://efts.sec.gov/LATEST/search-index?q=&dateRange=custom",
      "endpoints": [
        {
          "path": "/search-index?q={query}&dateRange=custom&startdt={start}&enddt={end}",
          "method": "GET",
          "desc": "Full-text search across SEC filings (10-K, 10-Q, 8-K, etc.)",
          "example": "curl -H 'User-Agent: MyApp/1.0 (contact@example.com)' 'https://efts.sec.gov/LATEST/search-index?q=artificial+intelligence&dateRange=custom&startdt=2024-01-01&enddt=2024-12-31'"
        },
        {
          "path": "https://data.sec.gov/submissions/CIK{cik_number}.json",
          "method": "GET",
          "desc": "Get all filings for a company by CIK number",
          "example": "curl -H 'User-Agent: MyApp/1.0 (contact@example.com)' 'https://data.sec.gov/submissions/CIK0000320193.json'"
        }
      ]
    },
    {
      "name": "BuiltWith",
      "base_url": "https://api.builtwith.com",
      "auth": "apiKey",
      "auth_param": "KEY",
      "auth_location": "query",
      "free_tier": "Free tier with limited lookups, shows technology stack for websites",
