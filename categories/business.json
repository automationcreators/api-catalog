      "docs_url": "https://developers.google.com/maps/documentation/places/web-service",
      "endpoints": [
        {
          "path": "/textsearch/json?query={query}&key={key}",
          "method": "GET",
          "desc": "Search places by text query (e.g., restaurants in San Francisco)",
          "example": "curl 'https://maps.googleapis.com/maps/api/place/textsearch/json?query=coffee+shops+in+austin&key=$GOOGLE_PLACES_API_KEY'"
        },
        {
          "path": "/details/json?place_id={place_id}&fields=name,rating,formatted_phone_number,website,reviews&key={key}",
          "method": "GET",
          "desc": "Get detailed info for a specific place including reviews and contact",
          "example": "curl 'https://maps.googleapis.com/maps/api/place/details/json?place_id=ChIJN1t_tDeuEmsRUsoyG83frY4&fields=name,rating,formatted_phone_number,website&key=$GOOGLE_PLACES_API_KEY'"
        },
        {
          "path": "/nearbysearch/json?location={lat},{lng}&radius={meters}&type={type}&key={key}",
          "method": "GET",
          "desc": "Search for places near a location by type (restaurant, gym, etc.)",
          "example": "curl 'https://maps.googleapis.com/maps/api/place/nearbysearch/json?location=30.267,-97.743&radius=1500&type=restaurant&key=$GOOGLE_PLACES_API_KEY'"
        }
      ]
