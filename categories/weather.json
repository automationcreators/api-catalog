{
  "category": "weather",
  "description": "Current conditions, forecasts, historical weather data, and severe weather alerts",
  "apis": [
    {
      "name": "OpenWeatherMap",
      "base_url": "https://api.openweathermap.org/data/2.5",
      "auth": "apiKey",
      "auth_param": "appid",
      "auth_location": "query",
      "free_tier": "60 calls/minute, 1,000,000 calls/month, current weather and 5-day forecast",
      "key_env_var": "OPENWEATHERMAP_API_KEY",
      "docs_url": "https://openweathermap.org/api",
      "endpoints": [
        {
          "path": "/weather?q={city}&units=imperial&appid={key}",
          "method": "GET",
          "desc": "Current weather conditions for a city",
          "example": "curl 'https://api.openweathermap.org/data/2.5/weather?q=Phoenix,AZ,US&units=imperial&appid=$OPENWEATHERMAP_API_KEY'"
        },
        {
          "path": "/forecast?q={city}&units=imperial&appid={key}",
          "method": "GET",
          "desc": "5-day / 3-hour forecast for a city",
          "example": "curl 'https://api.openweathermap.org/data/2.5/forecast?q=New+York&units=imperial&appid=$OPENWEATHERMAP_API_KEY'"
        },
        {
          "path": "/weather?lat={lat}&lon={lon}&units=metric&appid={key}",
          "method": "GET",
          "desc": "Current weather by geographic coordinates",
          "example": "curl 'https://api.openweathermap.org/data/2.5/weather?lat=33.4484&lon=-112.0740&units=imperial&appid=$OPENWEATHERMAP_API_KEY'"
        }
      ]
    },
    {
      "name": "Open-Meteo",
      "base_url": "https://api.open-meteo.com/v1",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, 10,000 requests/day for non-commercial use",
      "key_env_var": null,
      "docs_url": "https://open-meteo.com/en/docs",
      "endpoints": [
        {
          "path": "/forecast?latitude={lat}&longitude={lon}&current_weather=true",
          "method": "GET",
          "desc": "Current weather conditions by coordinates",
          "example": "curl 'https://api.open-meteo.com/v1/forecast?latitude=33.4484&longitude=-112.0740&current_weather=true'"
        },
        {
          "path": "/forecast?latitude={lat}&longitude={lon}&hourly=temperature_2m,precipitation_probability&forecast_days=7",
          "method": "GET",
          "desc": "7-day hourly forecast with customizable variables",
          "example": "curl 'https://api.open-meteo.com/v1/forecast?latitude=40.7128&longitude=-74.0060&hourly=temperature_2m,precipitation_probability&forecast_days=3&temperature_unit=fahrenheit'"
        },
        {
          "path": "/forecast?latitude={lat}&longitude={lon}&daily=temperature_2m_max,temperature_2m_min,precipitation_sum&timezone=auto",
          "method": "GET",
          "desc": "Daily aggregated forecast (highs, lows, precipitation)",
          "example": "curl 'https://api.open-meteo.com/v1/forecast?latitude=51.5074&longitude=-0.1278&daily=temperature_2m_max,temperature_2m_min,precipitation_sum&timezone=auto'"
        }
      ]
    },
    {
      "name": "WeatherAPI",
      "base_url": "https://api.weatherapi.com/v1",
      "auth": "apiKey",
      "auth_param": "key",
      "auth_location": "query",
      "free_tier": "1,000,000 calls/month, current + 3-day forecast + astronomy",
      "key_env_var": "WEATHERAPI_KEY",
      "docs_url": "https://www.weatherapi.com/docs/",
      "endpoints": [
        {
          "path": "/current.json?key={key}&q={location}",
          "method": "GET",
          "desc": "Current weather for a location (city name, ZIP, coordinates, or IP)",
          "example": "curl 'https://api.weatherapi.com/v1/current.json?key=$WEATHERAPI_KEY&q=85001'"
        },
        {
          "path": "/forecast.json?key={key}&q={location}&days=3",
          "method": "GET",
          "desc": "Weather forecast up to 3 days with hourly breakdown",
          "example": "curl 'https://api.weatherapi.com/v1/forecast.json?key=$WEATHERAPI_KEY&q=London&days=3'"
        },
        {
          "path": "/astronomy.json?key={key}&q={location}&dt={date}",
          "method": "GET",
          "desc": "Sunrise, sunset, moonrise, moonset, and moon phase",
          "example": "curl 'https://api.weatherapi.com/v1/astronomy.json?key=$WEATHERAPI_KEY&q=Phoenix&dt=2026-03-12'"
        }
      ]
    },
    {
      "name": "Visual Crossing",
      "base_url": "https://weather.visualcrossing.com/VisualCrossingWebServices/rest/services",
      "auth": "apiKey",
      "auth_param": "key",
      "auth_location": "query",
      "free_tier": "1,000 records/day, historical and forecast data",
      "key_env_var": "VISUAL_CROSSING_API_KEY",
      "docs_url": "https://www.visualcrossing.com/resources/documentation/weather-api/timeline-weather-api/",
      "endpoints": [
        {
          "path": "/timeline/{location}?unitGroup=us&key={key}&contentType=json",
          "method": "GET",
          "desc": "15-day forecast with current conditions for a location",
          "example": "curl 'https://weather.visualcrossing.com/VisualCrossingWebServices/rest/services/timeline/Phoenix,AZ?unitGroup=us&key=$VISUAL_CROSSING_API_KEY&contentType=json'"
        },
        {
          "path": "/timeline/{location}/{start_date}/{end_date}?unitGroup=us&key={key}&contentType=json",
          "method": "GET",
          "desc": "Historical weather data for a date range",
          "example": "curl 'https://weather.visualcrossing.com/VisualCrossingWebServices/rest/services/timeline/New+York/2025-01-01/2025-01-31?unitGroup=us&key=$VISUAL_CROSSING_API_KEY&contentType=json'"
        }
      ]
    },
    {
      "name": "Tomorrow.io",
      "base_url": "https://api.tomorrow.io/v4",
      "auth": "apiKey",
      "auth_param": "apikey",
      "auth_location": "query",
      "free_tier": "500 calls/day, 25 calls/hour, 3 calls/second",
      "key_env_var": "TOMORROW_IO_API_KEY",
      "docs_url": "https://docs.tomorrow.io/reference/welcome",
      "endpoints": [
        {
          "path": "/weather/realtime?location={lat},{lon}&apikey={key}",
          "method": "GET",
          "desc": "Real-time weather conditions with extensive data fields",
          "example": "curl 'https://api.tomorrow.io/v4/weather/realtime?location=33.4484,-112.0740&apikey=$TOMORROW_IO_API_KEY'"
        },
        {
          "path": "/weather/forecast?location={location}&timesteps=1d&apikey={key}",
          "method": "GET",
          "desc": "Daily forecast up to 5 days",
          "example": "curl 'https://api.tomorrow.io/v4/weather/forecast?location=New+York&timesteps=1d&apikey=$TOMORROW_IO_API_KEY'"
        },
        {
          "path": "/weather/forecast?location={lat},{lon}&timesteps=1h&apikey={key}",
          "method": "GET",
          "desc": "Hourly forecast up to 120 hours",
          "example": "curl 'https://api.tomorrow.io/v4/weather/forecast?location=40.7128,-74.0060&timesteps=1h&apikey=$TOMORROW_IO_API_KEY'"
        }
      ]
    },
    {
      "name": "Weatherbit",
      "base_url": "https://api.weatherbit.io/v2.0",
      "auth": "apiKey",
      "auth_param": "key",
      "auth_location": "query",
      "free_tier": "500 calls/day, current weather and 16-day forecast",
      "key_env_var": "WEATHERBIT_API_KEY",
      "docs_url": "https://www.weatherbit.io/api",
      "endpoints": [
        {
          "path": "/current?city={city}&country={country}&key={key}",
          "method": "GET",
          "desc": "Current weather conditions for a city",
          "example": "curl 'https://api.weatherbit.io/v2.0/current?city=Phoenix&country=US&key=$WEATHERBIT_API_KEY'"
        },
        {
          "path": "/forecast/daily?city={city}&country={country}&days=7&key={key}",
          "method": "GET",
          "desc": "Daily forecast up to 16 days",
          "example": "curl 'https://api.weatherbit.io/v2.0/forecast/daily?city=New+York&country=US&days=7&key=$WEATHERBIT_API_KEY'"
        }
      ]
    },
    {
      "name": "AmbientWeather",
      "base_url": "https://rt.ambientweather.net/v1",
      "auth": "apiKey",
      "auth_param": "applicationKey",
      "auth_location": "query",
      "free_tier": "Free tier with personal weather station data, 1 request/second",
      "key_env_var": "AMBIENT_APP_KEY",
      "docs_url": "https://ambientweather.docs.apiary.io/",
      "endpoints": [
        {
          "path": "/devices?applicationKey={appKey}&apiKey={apiKey}",
          "method": "GET",
          "desc": "List your registered weather station devices",
          "example": "curl 'https://rt.ambientweather.net/v1/devices?applicationKey=$AMBIENT_APP_KEY&apiKey=$AMBIENT_API_KEY'"
        },
        {
          "path": "/devices/{macAddress}?applicationKey={appKey}&apiKey={apiKey}&limit=10",
          "method": "GET",
          "desc": "Get recent data from a specific weather station by MAC address",
          "example": "curl 'https://rt.ambientweather.net/v1/devices/AA:BB:CC:DD:EE:FF?applicationKey=$AMBIENT_APP_KEY&apiKey=$AMBIENT_API_KEY&limit=10'"
        }
      ]
    },
    {
      "name": "Storm Glass",
      "base_url": "https://api.stormglass.io/v2",
      "auth": "apiKey",
      "auth_param": "Authorization",
      "auth_location": "header",
      "free_tier": "50 requests/day, marine and weather data",
      "key_env_var": "STORMGLASS_API_KEY",
      "docs_url": "https://docs.stormglass.io/",
      "endpoints": [
        {
          "path": "/weather/point?lat={lat}&lng={lon}&params=airTemperature,pressure,windSpeed,waveHeight",
          "method": "GET",
          "desc": "Get weather and marine data for a coordinate point",
          "example": "curl -H 'Authorization: $STORMGLASS_API_KEY' 'https://api.stormglass.io/v2/weather/point?lat=33.45&lng=-112.07&params=airTemperature,pressure,windSpeed'"
        },
        {
          "path": "/tide/extremes/point?lat={lat}&lng={lon}&start={start}&end={end}",
          "method": "GET",
          "desc": "Get tide high/low extremes for a coastal location",
          "example": "curl -H 'Authorization: $STORMGLASS_API_KEY' 'https://api.stormglass.io/v2/tide/extremes/point?lat=33.76&lng=-118.19&start=2026-03-12&end=2026-03-15'"
        }
      ]
    },
    {
      "name": "Oikolab (Historical Weather)",
      "base_url": "https://api.oikolab.com/weather",
      "auth": "apiKey",
      "auth_param": "api-key",
      "auth_location": "header",
      "free_tier": "Free tier with limited historical weather data requests",
      "key_env_var": "OIKOLAB_API_KEY",
      "docs_url": "https://docs.oikolab.com/",
      "endpoints": [
        {
          "path": "/?param=temperature&lat={lat}&lon={lon}&start={start}&end={end}&freq=D",
          "method": "GET",
          "desc": "Get historical daily temperature data for a location",
          "example": "curl -H 'api-key: $OIKOLAB_API_KEY' 'https://api.oikolab.com/weather/?param=temperature&lat=33.45&lon=-112.07&start=2025-01-01&end=2025-01-31&freq=D'"
        }
      ]
    },
    {
      "name": "Bright Sky (German Weather)",
      "base_url": "https://api.brightsky.dev",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, open data from Deutscher Wetterdienst (DWD)",
      "key_env_var": null,
      "docs_url": "https://brightsky.dev/docs/",
      "endpoints": [
        {
          "path": "/weather?lat={lat}&lon={lon}&date={date}",
          "method": "GET",
          "desc": "Hourly weather observations and forecasts for German locations",
          "example": "curl 'https://api.brightsky.dev/weather?lat=52.52&lon=13.40&date=2026-03-12'"
        },
        {
          "path": "/current_weather?lat={lat}&lon={lon}",
          "method": "GET",
          "desc": "Current weather conditions from nearest DWD station",
          "example": "curl 'https://api.brightsky.dev/current_weather?lat=48.14&lon=11.58'"
        }
      ]
    },
    {
      "name": "AEMET (Spanish Weather)",
      "base_url": "https://opendata.aemet.es/opendata/api",
      "auth": "apiKey",
      "auth_param": "api_key",
      "auth_location": "query",
      "free_tier": "Free key required, Spanish national weather data",
      "key_env_var": "AEMET_API_KEY",
      "docs_url": "https://opendata.aemet.es/dist/index.html",
      "endpoints": [
        {
          "path": "/prediccion/especifica/municipio/diaria/{municipio_id}?api_key={key}",
          "method": "GET",
          "desc": "Daily weather forecast for a Spanish municipality",
          "example": "curl 'https://opendata.aemet.es/opendata/api/prediccion/especifica/municipio/diaria/28079?api_key=$AEMET_API_KEY'"
        },
        {
          "path": "/observacion/convencional/todas?api_key={key}",
          "method": "GET",
          "desc": "Current observations from all AEMET weather stations",
          "example": "curl 'https://opendata.aemet.es/opendata/api/observacion/convencional/todas?api_key=$AEMET_API_KEY'"
        }
      ]
    },
    {
      "name": "Environment Canada Weather",
      "base_url": "https://dd.weather.gc.ca/api",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, open data from Environment and Climate Change Canada",
      "key_env_var": null,
      "docs_url": "https://eccc-msc.github.io/open-data/msc-geomet/readme_en/",
      "endpoints": [
        {
          "path": "/collections/climate-daily/items?f=json&limit=10&STATION_NAME={station}",
          "method": "GET",
          "desc": "Daily climate observations from Canadian weather stations",
          "example": "curl 'https://dd.weather.gc.ca/api/collections/climate-daily/items?f=json&limit=10&STATION_NAME=TORONTO'"
        },
        {
          "path": "/collections?f=json",
          "method": "GET",
          "desc": "List all available weather data collections",
          "example": "curl 'https://dd.weather.gc.ca/api/collections?f=json'"
        }
      ]
    },
    {
      "name": "World Air Quality Index (WAQI)",
      "base_url": "https://api.waqi.info",
      "auth": "apiKey",
      "auth_param": "token",
      "auth_location": "query",
      "free_tier": "Free tier with air quality data for 1,000+ cities worldwide",
      "key_env_var": "WAQI_API_KEY",
      "docs_url": "https://aqicn.org/json-api/doc/",
      "endpoints": [
        {
          "path": "/feed/{city}/?token={key}",
          "method": "GET",
          "desc": "Current air quality index for a city",
          "example": "curl 'https://api.waqi.info/feed/phoenix/?token=$WAQI_API_KEY'"
        },
        {
          "path": "/feed/geo:{lat};{lon}/?token={key}",
          "method": "GET",
          "desc": "Air quality data for nearest station to coordinates",
          "example": "curl 'https://api.waqi.info/feed/geo:33.45;-112.07/?token=$WAQI_API_KEY'"
        },
        {
          "path": "/search/?keyword={city}&token={key}",
          "method": "GET",
          "desc": "Search for air quality monitoring stations by keyword",
          "example": "curl 'https://api.waqi.info/search/?keyword=london&token=$WAQI_API_KEY'"
        }
      ]
    },
    {
      "name": "Google Pollen API",
      "base_url": "https://pollen.googleapis.com/v1",
      "auth": "apiKey",
      "auth_param": "key",
      "auth_location": "query",
      "free_tier": "Free with Google Cloud API key, standard quota limits",
      "key_env_var": "GOOGLE_POLLEN_API_KEY",
      "docs_url": "https://developers.google.com/maps/documentation/pollen",
      "endpoints": [
        {
          "path": "/forecast:lookup?location.longitude={lon}&location.latitude={lat}&days=3&key={key}",
          "method": "GET",
          "desc": "Pollen forecast for up to 5 days at a location",
          "example": "curl 'https://pollen.googleapis.com/v1/forecast:lookup?location.longitude=-112.07&location.latitude=33.45&days=3&key=$GOOGLE_POLLEN_API_KEY'"
        }
      ]
    },
    {
      "name": "UV Index API (Open-Meteo)",
      "base_url": "https://api.open-meteo.com/v1",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, part of Open-Meteo free tier (10,000 requests/day)",
      "key_env_var": null,
      "docs_url": "https://open-meteo.com/en/docs",
      "endpoints": [
        {
          "path": "/forecast?latitude={lat}&longitude={lon}&daily=uv_index_max,uv_index_clear_sky_max&timezone=auto",
          "method": "GET",
          "desc": "Daily maximum UV index forecast for a location",
          "example": "curl 'https://api.open-meteo.com/v1/forecast?latitude=33.45&longitude=-112.07&daily=uv_index_max,uv_index_clear_sky_max&timezone=auto'"
        },
        {
          "path": "/forecast?latitude={lat}&longitude={lon}&hourly=uv_index&timezone=auto&forecast_days=2",
          "method": "GET",
          "desc": "Hourly UV index forecast",
          "example": "curl 'https://api.open-meteo.com/v1/forecast?latitude=40.71&longitude=-74.01&hourly=uv_index&timezone=auto&forecast_days=2'"
        }
      ]
    },
    {
      "name": "National Weather Service",
      "base_url": "https://api.weather.gov",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, must include User-Agent header, US locations only",
      "key_env_var": null,
      "docs_url": "https://www.weather.gov/documentation/services-web-api",
      "endpoints": [
        {
          "path": "/points/{lat},{lon}",
          "method": "GET",
          "desc": "Get metadata and forecast URLs for a lat/lon point",
          "example": "curl -H 'User-Agent: api-catalog/1.0' 'https://api.weather.gov/points/33.4484,-112.0740'"
        },
        {
          "path": "/gridpoints/{office}/{gridX},{gridY}/forecast",
          "method": "GET",
          "desc": "7-day forecast for a grid point (get grid from /points endpoint)",
          "example": "curl -H 'User-Agent: api-catalog/1.0' 'https://api.weather.gov/gridpoints/PSR/159,61/forecast'"
        },
        {
          "path": "/alerts/active?area={state}",
          "method": "GET",
          "desc": "Active weather alerts for a US state",
          "example": "curl -H 'User-Agent: api-catalog/1.0' 'https://api.weather.gov/alerts/active?area=AZ'"
        }
      ]
    }
  ]
}
