{
  "category": "finance",
  "description": "Stock market data, cryptocurrency prices, economic indicators, and currency exchange rates",
  "apis": [
    {
      "name": "Alpha Vantage",
      "base_url": "https://www.alphavantage.co",
      "auth": "apiKey",
      "auth_param": "apikey",
      "auth_location": "query",
      "free_tier": "25 requests/day, 5 requests/minute",
      "key_env_var": "ALPHA_VANTAGE_API_KEY",
      "docs_url": "https://www.alphavantage.co/documentation/",
      "endpoints": [
        {
          "path": "/query?function=GLOBAL_QUOTE&symbol={symbol}&apikey={key}",
          "method": "GET",
          "desc": "Get real-time stock quote with price, volume, and change",
          "example": "curl 'https://www.alphavantage.co/query?function=GLOBAL_QUOTE&symbol=AAPL&apikey=$ALPHA_VANTAGE_API_KEY'"
        },
        {
          "path": "/query?function=TIME_SERIES_DAILY&symbol={symbol}&apikey={key}",
          "method": "GET",
          "desc": "Daily OHLCV time series for a stock (last 100 days)",
          "example": "curl 'https://www.alphavantage.co/query?function=TIME_SERIES_DAILY&symbol=MSFT&apikey=$ALPHA_VANTAGE_API_KEY'"
        },
        {
          "path": "/query?function=TIME_SERIES_INTRADAY&symbol={symbol}&interval=5min&apikey={key}",
          "method": "GET",
          "desc": "Intraday time series at 1, 5, 15, 30, or 60 minute intervals",
          "example": "curl 'https://www.alphavantage.co/query?function=TIME_SERIES_INTRADAY&symbol=TSLA&interval=5min&apikey=$ALPHA_VANTAGE_API_KEY'"
        }
      ]
    },
    {
      "name": "CoinGecko",
      "base_url": "https://api.coingecko.com/api/v3",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "10-30 calls/minute, no key required for public endpoints",
      "key_env_var": null,
      "docs_url": "https://docs.coingecko.com/reference/introduction",
      "endpoints": [
        {
          "path": "/simple/price?ids={coin_ids}&vs_currencies={currencies}",
          "method": "GET",
          "desc": "Current price for one or more coins in specified currencies",
          "example": "curl 'https://api.coingecko.com/api/v3/simple/price?ids=bitcoin,ethereum&vs_currencies=usd'"
        },
        {
          "path": "/coins/{id}/market_chart?vs_currency=usd&days={days}",
          "method": "GET",
          "desc": "Historical market data including price, market cap, and volume",
          "example": "curl 'https://api.coingecko.com/api/v3/coins/bitcoin/market_chart?vs_currency=usd&days=30'"
        },
        {
          "path": "/coins/markets?vs_currency=usd&order=market_cap_desc&per_page=100&page=1",
          "method": "GET",
          "desc": "Top coins by market cap with price, volume, and 24h change",
          "example": "curl 'https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&order=market_cap_desc&per_page=10&page=1'"
        }
      ]
    },
    {
      "name": "Finnhub",
      "base_url": "https://finnhub.io/api/v1",
      "auth": "apiKey",
      "auth_param": "token",
      "auth_location": "query",
      "free_tier": "60 API calls/minute",
      "key_env_var": "FINNHUB_API_KEY",
      "docs_url": "https://finnhub.io/docs/api",
      "endpoints": [
        {
          "path": "/quote?symbol={symbol}&token={key}",
          "method": "GET",
          "desc": "Real-time quote with current, high, low, open, previous close",
          "example": "curl 'https://finnhub.io/api/v1/quote?symbol=AAPL&token=$FINNHUB_API_KEY'"
        },
        {
          "path": "/stock/candle?symbol={symbol}&resolution=D&from={unix_start}&to={unix_end}&token={key}",
          "method": "GET",
          "desc": "Stock candle (OHLCV) data at various resolutions",
          "example": "curl 'https://finnhub.io/api/v1/stock/candle?symbol=AAPL&resolution=D&from=1704067200&to=1706745600&token=$FINNHUB_API_KEY'"
        },
        {
          "path": "/company-news?symbol={symbol}&from={date}&to={date}&token={key}",
          "method": "GET",
          "desc": "Company news articles within a date range",
          "example": "curl 'https://finnhub.io/api/v1/company-news?symbol=AAPL&from=2026-03-01&to=2026-03-12&token=$FINNHUB_API_KEY'"
        }
      ]
    },
    {
      "name": "FRED (Federal Reserve Economic Data)",
      "base_url": "https://api.stlouisfed.org/fred",
      "auth": "apiKey",
      "auth_param": "api_key",
      "auth_location": "query",
      "free_tier": "120 requests/minute, unlimited daily",
      "key_env_var": "FRED_API_KEY",
      "docs_url": "https://fred.stlouisfed.org/docs/api/fred/",
      "endpoints": [
        {
          "path": "/series/observations?series_id={series_id}&api_key={key}&file_type=json",
          "method": "GET",
          "desc": "Get observations/values for an economic data series",
          "example": "curl 'https://api.stlouisfed.org/fred/series/observations?series_id=GDP&api_key=$FRED_API_KEY&file_type=json'"
        },
        {
          "path": "/series/search?search_text={query}&api_key={key}&file_type=json",
          "method": "GET",
          "desc": "Search for economic data series by keyword",
          "example": "curl 'https://api.stlouisfed.org/fred/series/search?search_text=unemployment+rate&api_key=$FRED_API_KEY&file_type=json'"
        },
        {
          "path": "/series?series_id={series_id}&api_key={key}&file_type=json",
          "method": "GET",
          "desc": "Get metadata for a specific series (title, frequency, units)",
          "example": "curl 'https://api.stlouisfed.org/fred/series?series_id=CPIAUCSL&api_key=$FRED_API_KEY&file_type=json'"
        }
      ]
    },
    {
      "name": "ExchangeRate-API",
      "base_url": "https://open.er-api.com/v6",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required for open API, updates daily",
      "key_env_var": null,
      "docs_url": "https://www.exchangerate-api.com/docs/free",
      "endpoints": [
        {
          "path": "/latest/{base_currency}",
          "method": "GET",
          "desc": "Latest exchange rates for a base currency against all others",
          "example": "curl 'https://open.er-api.com/v6/latest/USD'"
        },
        {
          "path": "/latest/{base_currency}",
          "method": "GET",
          "desc": "Convert between currencies using the rates in the response",
          "example": "curl 'https://open.er-api.com/v6/latest/EUR'"
        }
      ]
    },
    {
      "name": "Twelve Data",
      "base_url": "https://api.twelvedata.com",
      "auth": "apiKey",
      "auth_param": "apikey",
      "auth_location": "query",
      "free_tier": "800 API credits/day, 8 credits/minute",
      "key_env_var": "TWELVE_DATA_API_KEY",
      "docs_url": "https://twelvedata.com/docs",
      "endpoints": [
        {
          "path": "/time_series?symbol={symbol}&interval=1day&outputsize=30&apikey={key}",
          "method": "GET",
          "desc": "Time series data for stocks, forex, or crypto",
          "example": "curl 'https://api.twelvedata.com/time_series?symbol=AAPL&interval=1day&outputsize=30&apikey=$TWELVE_DATA_API_KEY'"
        },
        {
          "path": "/price?symbol={symbol}&apikey={key}",
          "method": "GET",
          "desc": "Real-time or latest price for a symbol",
          "example": "curl 'https://api.twelvedata.com/price?symbol=EUR/USD&apikey=$TWELVE_DATA_API_KEY'"
        },
        {
          "path": "/quote?symbol={symbol}&apikey={key}",
          "method": "GET",
          "desc": "Detailed quote with 52-week high/low, volume, averages",
          "example": "curl 'https://api.twelvedata.com/quote?symbol=GOOGL&apikey=$TWELVE_DATA_API_KEY'"
        }
      ]
    },
    {
      "name": "Yahoo Finance (Unofficial)",
      "base_url": "https://query1.finance.yahoo.com/v8",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, unofficial endpoints, rate limited",
      "key_env_var": null,
      "docs_url": "https://github.com/ranaroussi/yfinance",
      "endpoints": [
        {
          "path": "/finance/chart/{symbol}?interval=1d&range=1mo",
          "method": "GET",
          "desc": "Historical price chart data for a stock or ETF",
          "example": "curl 'https://query1.finance.yahoo.com/v8/finance/chart/AAPL?interval=1d&range=1mo'"
        },
        {
          "path": "/finance/chart/{symbol}?interval=5m&range=1d",
          "method": "GET",
          "desc": "Intraday chart data at 5-minute intervals",
          "example": "curl 'https://query1.finance.yahoo.com/v8/finance/chart/TSLA?interval=5m&range=1d'"
        },
        {
          "path": "/finance/chart/{symbol}?interval=1wk&range=1y",
          "method": "GET",
          "desc": "Weekly price data for the past year",
          "example": "curl 'https://query1.finance.yahoo.com/v8/finance/chart/MSFT?interval=1wk&range=1y'"
        }
      ]
    },
    {
      "name": "Polygon.io",
      "base_url": "https://api.polygon.io",
      "auth": "apiKey",
      "auth_param": "apiKey",
      "auth_location": "query",
      "free_tier": "5 API calls/minute, end-of-day data, 2 years historical",
      "key_env_var": "POLYGON_API_KEY",
      "docs_url": "https://polygon.io/docs/stocks",
      "endpoints": [
        {
          "path": "/v2/aggs/ticker/{symbol}/prev?adjusted=true&apiKey={key}",
          "method": "GET",
          "desc": "Previous day's OHLCV bar for a stock ticker",
          "example": "curl 'https://api.polygon.io/v2/aggs/ticker/AAPL/prev?adjusted=true&apiKey=$POLYGON_API_KEY'"
        },
        {
          "path": "/v2/aggs/ticker/{symbol}/range/1/day/{from}/{to}?adjusted=true&apiKey={key}",
          "method": "GET",
          "desc": "Aggregate bars for a stock over a date range",
          "example": "curl 'https://api.polygon.io/v2/aggs/ticker/AAPL/range/1/day/2026-01-01/2026-03-01?adjusted=true&apiKey=$POLYGON_API_KEY'"
        },
        {
          "path": "/v3/reference/tickers?search={query}&active=true&limit=10&apiKey={key}",
          "method": "GET",
          "desc": "Search for stock tickers by name or symbol",
          "example": "curl 'https://api.polygon.io/v3/reference/tickers?search=apple&active=true&limit=10&apiKey=$POLYGON_API_KEY'"
        }
      ]
    },
    {
      "name": "IEX Cloud",
      "base_url": "https://cloud.iexapis.com/stable",
      "auth": "apiKey",
      "auth_param": "token",
      "auth_location": "query",
      "free_tier": "Free tier with limited message credits, core data access",
      "key_env_var": "IEX_CLOUD_API_KEY",
      "docs_url": "https://iexcloud.io/docs/",
      "endpoints": [
        {
          "path": "/stock/{symbol}/quote?token={key}",
          "method": "GET",
          "desc": "Real-time stock quote with key metrics",
          "example": "curl 'https://cloud.iexapis.com/stable/stock/AAPL/quote?token=$IEX_CLOUD_API_KEY'"
        },
        {
          "path": "/stock/{symbol}/chart/1m?token={key}",
          "method": "GET",
          "desc": "Historical price data for the last month",
          "example": "curl 'https://cloud.iexapis.com/stable/stock/MSFT/chart/1m?token=$IEX_CLOUD_API_KEY'"
        },
        {
          "path": "/stock/{symbol}/company?token={key}",
          "method": "GET",
          "desc": "Company profile including sector, industry, and description",
          "example": "curl 'https://cloud.iexapis.com/stable/stock/GOOGL/company?token=$IEX_CLOUD_API_KEY'"
        }
      ]
    },
    {
      "name": "Binance",
      "base_url": "https://api.binance.com/api/v3",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required for public endpoints, 1200 requests/minute",
      "key_env_var": null,
      "docs_url": "https://binance-docs.github.io/apidocs/spot/en/",
      "endpoints": [
        {
          "path": "/ticker/price?symbol={symbol}",
          "method": "GET",
          "desc": "Latest price for a trading pair",
          "example": "curl 'https://api.binance.com/api/v3/ticker/price?symbol=BTCUSDT'"
        },
        {
          "path": "/ticker/24hr?symbol={symbol}",
          "method": "GET",
          "desc": "24-hour rolling price change statistics",
          "example": "curl 'https://api.binance.com/api/v3/ticker/24hr?symbol=ETHUSDT'"
        },
        {
          "path": "/klines?symbol={symbol}&interval=1d&limit=30",
          "method": "GET",
          "desc": "Kline/candlestick data for a trading pair",
          "example": "curl 'https://api.binance.com/api/v3/klines?symbol=BTCUSDT&interval=1d&limit=30'"
        }
      ]
    },
    {
      "name": "Kraken",
      "base_url": "https://api.kraken.com/0/public",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required for public endpoints, 1 request/second",
      "key_env_var": null,
      "docs_url": "https://docs.kraken.com/rest/",
      "endpoints": [
        {
          "path": "/Ticker?pair={pair}",
          "method": "GET",
          "desc": "Current ticker info including ask, bid, last trade, volume",
          "example": "curl 'https://api.kraken.com/0/public/Ticker?pair=XBTUSD'"
        },
        {
          "path": "/OHLC?pair={pair}&interval=1440",
          "method": "GET",
          "desc": "OHLC candlestick data at specified interval (minutes)",
          "example": "curl 'https://api.kraken.com/0/public/OHLC?pair=ETHUSD&interval=1440'"
        },
        {
          "path": "/Assets",
          "method": "GET",
          "desc": "List all available assets and their details",
          "example": "curl 'https://api.kraken.com/0/public/Assets'"
        }
      ]
    },
    {
      "name": "Fixer.io",
      "base_url": "https://data.fixer.io/api",
      "auth": "apiKey",
      "auth_param": "access_key",
      "auth_location": "query",
      "free_tier": "100 requests/month, EUR base only on free tier",
      "key_env_var": "FIXER_API_KEY",
      "docs_url": "https://fixer.io/documentation",
      "endpoints": [
        {
          "path": "/latest?access_key={key}&symbols=USD,GBP,JPY",
          "method": "GET",
          "desc": "Latest exchange rates from EUR base to specified currencies",
          "example": "curl 'https://data.fixer.io/api/latest?access_key=$FIXER_API_KEY&symbols=USD,GBP,JPY'"
        },
        {
          "path": "/{date}?access_key={key}&symbols=USD,GBP",
          "method": "GET",
          "desc": "Historical exchange rates for a specific date (YYYY-MM-DD)",
          "example": "curl 'https://data.fixer.io/api/2026-01-15?access_key=$FIXER_API_KEY&symbols=USD,GBP'"
        },
        {
          "path": "/symbols?access_key={key}",
          "method": "GET",
          "desc": "List all available currency symbols",
          "example": "curl 'https://data.fixer.io/api/symbols?access_key=$FIXER_API_KEY'"
        }
      ]
    },
    {
      "name": "Coinbase",
      "base_url": "https://api.coinbase.com/v2",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required for exchange rate endpoints",
      "key_env_var": null,
      "docs_url": "https://docs.cloud.coinbase.com/sign-in-with-coinbase/docs/api-exchange-rates",
      "endpoints": [
        {
          "path": "/exchange-rates?currency={currency}",
          "method": "GET",
          "desc": "Exchange rates for a given currency against all others",
          "example": "curl 'https://api.coinbase.com/v2/exchange-rates?currency=BTC'"
        },
        {
          "path": "/prices/{pair}/spot",
          "method": "GET",
          "desc": "Current spot price for a currency pair",
          "example": "curl 'https://api.coinbase.com/v2/prices/BTC-USD/spot'"
        },
        {
          "path": "/currencies",
          "method": "GET",
          "desc": "List all supported fiat currencies",
          "example": "curl 'https://api.coinbase.com/v2/currencies'"
        }
      ]
    },
    {
      "name": "Morningstar",
      "base_url": "https://api-global.morningstar.com/sal-service/v1",
      "auth": "apiKey",
      "auth_param": "apikey",
      "auth_location": "header",
      "free_tier": "Limited free endpoints for basic fund/stock data",
      "key_env_var": "MORNINGSTAR_API_KEY",
      "docs_url": "https://developer.morningstar.com/direct-web-services/documentation",
      "endpoints": [
        {
          "path": "/stock/valuation/v2/{secId}?apikey={key}",
          "method": "GET",
          "desc": "Valuation metrics for a stock (P/E, P/B, P/S ratios)",
          "example": "curl -H 'apikey: $MORNINGSTAR_API_KEY' 'https://api-global.morningstar.com/sal-service/v1/stock/valuation/v2/0P0000OQN8'"
        },
        {
          "path": "/stock/newKeyStats/{secId}?apikey={key}",
          "method": "GET",
          "desc": "Key statistics including market cap, dividend yield, and growth",
          "example": "curl -H 'apikey: $MORNINGSTAR_API_KEY' 'https://api-global.morningstar.com/sal-service/v1/stock/newKeyStats/0P0000OQN8'"
        }
      ]
    },
    {
      "name": "World Bank API",
      "base_url": "https://api.worldbank.org/v2",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, generous rate limits",
      "key_env_var": null,
      "docs_url": "https://datahelpdesk.worldbank.org/knowledgebase/articles/889392",
      "endpoints": [
        {
          "path": "/country/{country_code}/indicator/NY.GDP.MKTP.CD?format=json&date=2015:2024",
          "method": "GET",
          "desc": "GDP data for a country over a date range",
          "example": "curl 'https://api.worldbank.org/v2/country/US/indicator/NY.GDP.MKTP.CD?format=json&date=2015:2024'"
        },
        {
          "path": "/country/{country_code}/indicator/FP.CPI.TOTL.ZG?format=json&mrv=10",
          "method": "GET",
          "desc": "Inflation rate (consumer prices, annual %) for most recent values",
          "example": "curl 'https://api.worldbank.org/v2/country/US/indicator/FP.CPI.TOTL.ZG?format=json&mrv=10'"
        },
        {
          "path": "/country?format=json&per_page=300",
          "method": "GET",
          "desc": "List all countries with income level, region, and codes",
          "example": "curl 'https://api.worldbank.org/v2/country?format=json&per_page=300'"
        }
      ]
    },
    {
      "name": "OpenFIGI",
      "base_url": "https://api.openfigi.com",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, 5 requests/minute (25/min with free API key)",
      "key_env_var": null,
      "docs_url": "https://www.openfigi.com/api",
      "endpoints": [
        {
          "path": "/v3/mapping",
          "method": "POST",
          "desc": "Map financial identifiers (ticker, CUSIP, ISIN) to FIGI",
          "example": "curl -X POST 'https://api.openfigi.com/v3/mapping' -H 'Content-Type: application/json' -d '[{\"idType\":\"TICKER\",\"idValue\":\"AAPL\"}]'"
        },
        {
          "path": "/v3/search",
          "method": "POST",
          "desc": "Search for financial instruments by name or keyword",
          "example": "curl -X POST 'https://api.openfigi.com/v3/search' -H 'Content-Type: application/json' -d '{\"query\":\"Apple Inc\"}'"
        }
      ]
    }
  ]
}