{
  "category": "security",
  "description": "Vulnerability scanning, malware detection, breach checking, and security APIs",
  "apis": [
    {
      "name": "AbuseIPDB",
      "description": "IP/domain/URL reputation",
      "base_url": "https://api.abuseipdb.com/api/v2",
      "auth": "apiKey",
      "auth_param": "key",
      "auth_location": "query",
      "free_tier": "See docs",
      "key_env_var": "ABUSEIPDB_API_KEY",
      "docs_url": "https://docs.abuseipdb.com/",
      "tier": 1,
      "endpoints": [
        {
          "path": "/check?ipAddress={ip}&maxAgeInDays=90",
          "method": "GET",
          "desc": "Check if an IP has been reported as abusive",
          "example": "curl -H 'Key: $ABUSEIPDB_API_KEY' -H 'Accept: application/json' 'https://api.abuseipdb.com/api/v2/check?ipAddress=118.25.6.39&maxAgeInDays=90'"
        },
        {
          "path": "/blacklist?limit=10",
          "method": "GET",
          "desc": "Get most reported IP addresses",
          "example": "curl -H 'Key: $ABUSEIPDB_API_KEY' -H 'Accept: application/json' 'https://api.abuseipdb.com/api/v2/blacklist?limit=10'"
        }
      ]
    },
