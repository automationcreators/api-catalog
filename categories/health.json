        {
          "path": "/foods/search?query={food}&api_key={key}&pageSize=5",
          "method": "GET",
          "desc": "Search foods with nutrition data",
          "example": "curl 'https://api.nal.usda.gov/fdc/v1/foods/search?query=banana&api_key=$USDA_API_KEY&pageSize=5'"
        },
        {
          "path": "/food/{fdcId}?api_key={key}",
          "method": "GET",
          "desc": "Get detailed nutrition for a specific food",
          "example": "curl 'https://api.nal.usda.gov/fdc/v1/food/534358?api_key=$USDA_API_KEY'"
