        }
      ]
    },
    {
      "name": "Stack Exchange API",
      "base_url": "https://api.stackexchange.com/2.3",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required for basic (300 requests/day), free key gets 10,000/day",
      "key_env_var": null,
      "docs_url": "https://api.stackexchange.com/docs",
      "endpoints": [
        {
          "path": "/questions?order=desc&sort=votes&tagged={tag}&site=stackoverflow&pagesize=10",
          "method": "GET",
          "desc": "Top voted questions by tag on Stack Overflow",
          "example": "curl 'https://api.stackexchange.com/2.3/questions?order=desc&sort=votes&tagged=python&site=stackoverflow&pagesize=10'"
        },
        {
          "path": "/search/advanced?order=desc&sort=relevance&q={query}&site=stackoverflow&pagesize=10",
          "method": "GET",
          "desc": "Advanced search across Stack Overflow questions",
          "example": "curl 'https://api.stackexchange.com/2.3/search/advanced?order=desc&sort=relevance&q=nextjs+server+actions&site=stackoverflow&pagesize=10'"
        },
        {
          "path": "/questions/{ids}/answers?order=desc&sort=votes&site=stackoverflow",
          "method": "GET",
          "desc": "Get answers for a specific question by ID",
          "example": "curl 'https://api.stackexchange.com/2.3/questions/12345678/answers?order=desc&sort=votes&site=stackoverflow'"
        }
      ]
