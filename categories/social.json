{
  "category": "social",
  "description": "Social platforms, forums, and developer communities with public read-only access",
  "apis": [
    {
      "name": "Reddit JSON API",
      "base_url": "https://www.reddit.com",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, append .json to any Reddit URL. ~10 requests/min, User-Agent required",
      "key_env_var": null,
      "docs_url": "https://www.reddit.com/dev/api/",
      "endpoints": [
        {
          "path": "/r/{subreddit}/hot.json?limit=25",
          "method": "GET",
          "desc": "Hot posts from a subreddit",
          "example": "curl -H 'User-Agent: api-catalog/1.0' 'https://www.reddit.com/r/programming/hot.json?limit=10'"
        },
        {
          "path": "/r/{subreddit}/top.json?t=week&limit=10",
          "method": "GET",
          "desc": "Top posts from a subreddit by time period (hour, day, week, month, year, all)",
          "example": "curl -H 'User-Agent: api-catalog/1.0' 'https://www.reddit.com/r/MachineLearning/top.json?t=week&limit=10'"
        },
        {
          "path": "/r/{subreddit}/search.json?q={query}&sort=relevance&restrict_sr=1",
          "method": "GET",
          "desc": "Search posts within a specific subreddit",
          "example": "curl -H 'User-Agent: api-catalog/1.0' 'https://www.reddit.com/r/webdev/search.json?q=nextjs&sort=top&restrict_sr=1&t=month'"
        },
        {
          "path": "/user/{username}/submitted.json?limit=10",
          "method": "GET",
          "desc": "A user's public submissions",
          "example": "curl -H 'User-Agent: api-catalog/1.0' 'https://www.reddit.com/user/spez/submitted.json?limit=5'"
        }
      ]
    },
    {
      "name": "HackerNews Firebase API",
      "base_url": "https://hacker-news.firebaseio.com/v0",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, no documented rate limit (Firebase backed)",
      "key_env_var": null,
      "docs_url": "https://github.com/HackerNews/API",
      "endpoints": [
        {
          "path": "/topstories.json",
          "method": "GET",
          "desc": "IDs of up to 500 current top stories",
          "example": "curl 'https://hacker-news.firebaseio.com/v0/topstories.json'"
        },
        {
          "path": "/item/{id}.json",
          "method": "GET",
          "desc": "Get a specific item (story, comment, job, poll) by ID",
          "example": "curl 'https://hacker-news.firebaseio.com/v0/item/39800000.json'"
        },
        {
          "path": "/newstories.json",
          "method": "GET",
          "desc": "IDs of up to 500 newest stories",
          "example": "curl 'https://hacker-news.firebaseio.com/v0/newstories.json'"
        },
        {
          "path": "/user/{username}.json",
          "method": "GET",
          "desc": "User profile with karma and submitted item IDs",
          "example": "curl 'https://hacker-news.firebaseio.com/v0/user/pg.json'"
        }
      ]
    },
    {
      "name": "Product Hunt API",
      "base_url": "https://api.producthunt.com/v2/api/graphql",
      "auth": "bearer",
      "auth_param": "Authorization",
      "auth_location": "header",
      "free_tier": "Developer token available, rate limits apply per token",
      "key_env_var": "PRODUCTHUNT_TOKEN",
      "docs_url": "https://api.producthunt.com/v2/docs",
      "endpoints": [
        {
          "path": "/",
          "method": "POST",
          "desc": "Get today's featured posts via GraphQL query",
          "example": "curl -X POST 'https://api.producthunt.com/v2/api/graphql' -H 'Authorization: Bearer $PRODUCTHUNT_TOKEN' -H 'Content-Type: application/json' -d '{\"query\":\"{ posts(order: RANKING) { edges { node { name tagline url votesCount } } } }\"}'"
        },
        {
          "path": "/",
          "method": "POST",
          "desc": "Search for products by topic",
          "example": "curl -X POST 'https://api.producthunt.com/v2/api/graphql' -H 'Authorization: Bearer $PRODUCTHUNT_TOKEN' -H 'Content-Type: application/json' -d '{\"query\":\"{ posts(topic: \\\"artificial-intelligence\\\", first: 10) { edges { node { name tagline votesCount } } } }\"}'"
        }
      ]
    },
    {
      "name": "DEV.to API",
      "base_url": "https://dev.to/api",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required for reading, 30 requests/30 seconds for unauthenticated",
      "key_env_var": null,
      "docs_url": "https://developers.forem.com/api/v1",
      "endpoints": [
        {
          "path": "/articles?per_page=10&top=7",
          "method": "GET",
          "desc": "Top articles from the past N days",
          "example": "curl 'https://dev.to/api/articles?per_page=10&top=7'"
        },
        {
          "path": "/articles?tag={tag}&per_page=10",
          "method": "GET",
          "desc": "Articles filtered by tag",
          "example": "curl 'https://dev.to/api/articles?tag=python&per_page=10'"
        },
        {
          "path": "/articles/{id}",
          "method": "GET",
          "desc": "Full article with body HTML by article ID",
          "example": "curl 'https://dev.to/api/articles/1234567'"
        }
      ]
    },
    {
      "name": "Mastodon API",
