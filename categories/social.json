    {
      "name": "Wikipedia API (MediaWiki)",
      "base_url": "https://en.wikipedia.org/w",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, polite User-Agent requested, no hard rate limit",
      "key_env_var": null,
      "docs_url": "https://www.mediawiki.org/wiki/API:Main_page",
      "endpoints": [
        {
          "path": "/api.php?action=query&titles={title}&prop=extracts&exintro&explaintext&format=json",
          "method": "GET",
          "desc": "Get the introduction/summary of a Wikipedia article",
          "example": "curl 'https://en.wikipedia.org/w/api.php?action=query&titles=Artificial_intelligence&prop=extracts&exintro&explaintext&format=json'"
        },
        {
          "path": "/api.php?action=opensearch&search={query}&limit=10&format=json",
          "method": "GET",
          "desc": "Search Wikipedia article titles with suggestions",
          "example": "curl 'https://en.wikipedia.org/w/api.php?action=opensearch&search=machine+learning&limit=10&format=json'"
        },
        {
          "path": "/api.php?action=query&list=search&srsearch={query}&srlimit=10&format=json",
          "method": "GET",
          "desc": "Full-text search across Wikipedia articles",
          "example": "curl 'https://en.wikipedia.org/w/api.php?action=query&list=search&srsearch=large+language+models&srlimit=10&format=json'"
        }
      ]
    },
    {
      "name": "Wikidata SPARQL",
      "base_url": "https://query.wikidata.org",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, User-Agent required, reasonable rate limiting",
      "key_env_var": null,
      "docs_url": "https://www.wikidata.org/wiki/Wikidata:SPARQL_query_service",
      "endpoints": [
        {
          "path": "/sparql?query={sparql_query}&format=json",
          "method": "GET",
          "desc": "Execute SPARQL queries against the Wikidata knowledge graph",
          "example": "curl -H 'User-Agent: api-catalog/1.0' 'https://query.wikidata.org/sparql?query=SELECT%20%3Fitem%20%3FitemLabel%20WHERE%20%7B%20%3Fitem%20wdt%3AP31%20wd%3AQ5%20.%20%3Fitem%20wdt%3AP106%20wd%3AQ82594%20.%20SERVICE%20wikibase%3Alabel%20%7B%20bd%3AserviceParam%20wikibase%3Alanguage%20%22en%22%20%7D%20%7D%20LIMIT%2010&format=json'"
        }
      ]
    },
