{
  "category": "geo",
  "description": "Geocoding, reverse geocoding, IP geolocation, and mapping services",
  "apis": [
    {
      "name": "Nominatim (OpenStreetMap)",
      "base_url": "https://nominatim.openstreetmap.org",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, max 1 request/second, must include User-Agent",
      "key_env_var": null,
      "docs_url": "https://nominatim.org/release-docs/latest/api/Overview/",
      "endpoints": [
        {
          "path": "/search?q={address}&format=json&limit=5",
          "method": "GET",
          "desc": "Forward geocode an address or place name to coordinates",
          "example": "curl -H 'User-Agent: api-catalog/1.0' 'https://nominatim.openstreetmap.org/search?q=1600+Pennsylvania+Ave+Washington+DC&format=json&limit=1'"
        },
        {
          "path": "/reverse?lat={lat}&lon={lon}&format=json",
          "method": "GET",
          "desc": "Reverse geocode coordinates to an address",
          "example": "curl -H 'User-Agent: api-catalog/1.0' 'https://nominatim.openstreetmap.org/reverse?lat=40.7484&lon=-73.9857&format=json'"
        },
        {
          "path": "/lookup?osm_ids=R{relation_id},N{node_id}&format=json",
          "method": "GET",
          "desc": "Look up address details for OSM objects by their IDs",
          "example": "curl -H 'User-Agent: api-catalog/1.0' 'https://nominatim.openstreetmap.org/lookup?osm_ids=R146656,N240109189&format=json'"
        }
      ]
    },
    {
      "name": "IP-API",
      "base_url": "http://ip-api.com",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, 45 requests/minute, HTTP only on free tier",
      "key_env_var": null,
      "docs_url": "https://ip-api.com/docs/",
      "endpoints": [
        {
          "path": "/json/{ip}",
          "method": "GET",
          "desc": "Geolocation data for a specific IP address",
          "example": "curl 'http://ip-api.com/json/8.8.8.8'"
        },
        {
          "path": "/json/",
          "method": "GET",
          "desc": "Geolocation data for the requesting IP address",
          "example": "curl 'http://ip-api.com/json/'"
        },
        {
          "path": "/batch",
          "method": "POST",
          "desc": "Batch geolocation lookup for up to 100 IPs",
          "example": "curl -X POST 'http://ip-api.com/batch' -H 'Content-Type: application/json' -d '[\"8.8.8.8\",\"1.1.1.1\"]'"
        }
      ]
    },
    {
      "name": "OpenCage Geocoding",
      "base_url": "https://api.opencagedata.com/geocode/v1",
      "auth": "apiKey",
      "auth_param": "key",
      "auth_location": "query",
      "free_tier": "2,500 requests/day, 1 request/second",
      "key_env_var": "OPENCAGE_API_KEY",
      "docs_url": "https://opencagedata.com/api",
      "endpoints": [
        {
          "path": "/json?q={address}&key={key}",
          "method": "GET",
          "desc": "Forward geocode an address to latitude/longitude with confidence score",
          "example": "curl 'https://api.opencagedata.com/geocode/v1/json?q=Berlin+Germany&key=$OPENCAGE_API_KEY'"
        },
        {
          "path": "/json?q={lat}+{lon}&key={key}",
          "method": "GET",
          "desc": "Reverse geocode coordinates to a formatted address",
          "example": "curl 'https://api.opencagedata.com/geocode/v1/json?q=51.5074+-0.1278&key=$OPENCAGE_API_KEY'"
        }
      ]
    },
    {
      "name": "BigDataCloud",
      "base_url": "https://api.bigdatacloud.net/data",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required for free endpoints, 50,000 requests/month on free tier",
      "key_env_var": null,
      "docs_url": "https://www.bigdatacloud.com/docs",
      "endpoints": [
        {
          "path": "/reverse-geocode-client?latitude={lat}&longitude={lon}&localityLanguage=en",
          "method": "GET",
          "desc": "Client-side reverse geocoding with locality information",
          "example": "curl 'https://api.bigdatacloud.net/data/reverse-geocode-client?latitude=37.7749&longitude=-122.4194&localityLanguage=en'"
        },
        {
          "path": "/client-ip",
          "method": "GET",
          "desc": "Get the requesting client's IP address",
          "example": "curl 'https://api.bigdatacloud.net/data/client-ip'"
        }
      ]
    },
    {
      "name": "ipinfo.io",
      "base_url": "https://ipinfo.io",
      "auth": "bearer",
      "auth_param": "Authorization",
      "auth_location": "header",
      "free_tier": "50,000 requests/month, basic IP data without token",
      "key_env_var": "IPINFO_TOKEN",
      "docs_url": "https://ipinfo.io/developers",
      "endpoints": [
        {
          "path": "/{ip}?token={key}",
          "method": "GET",
          "desc": "Full geolocation and org data for an IP address",
          "example": "curl 'https://ipinfo.io/8.8.8.8?token=$IPINFO_TOKEN'"
        },
        {
          "path": "/{ip}/geo?token={key}",
          "method": "GET",
          "desc": "Only geographic data (city, region, country, coordinates)",
          "example": "curl 'https://ipinfo.io/8.8.8.8/geo?token=$IPINFO_TOKEN'"
        },
        {
          "path": "/json?token={key}",
          "method": "GET",
          "desc": "Geolocation for the requesting IP",
          "example": "curl 'https://ipinfo.io/json?token=$IPINFO_TOKEN'"
        }
      ]
    },
    {
      "name": "ipgeolocation.io",
      "base_url": "https://api.ipgeolocation.io",
      "auth": "apiKey",
      "auth_param": "apiKey",
      "auth_location": "query",
      "free_tier": "1,000 requests/day, 30,000 requests/month",
      "key_env_var": "IPGEOLOCATION_API_KEY",
      "docs_url": "https://ipgeolocation.io/documentation.html",
      "endpoints": [
        {
          "path": "/ipgeo?apiKey={key}&ip={ip}",
          "method": "GET",
          "desc": "Full IP geolocation with ISP, currency, and timezone data",
          "example": "curl 'https://api.ipgeolocation.io/ipgeo?apiKey=$IPGEOLOCATION_API_KEY&ip=8.8.8.8'"
        },
        {
          "path": "/timezone?apiKey={key}&lat={lat}&long={lon}",
          "method": "GET",
          "desc": "Timezone information for given coordinates",
          "example": "curl 'https://api.ipgeolocation.io/timezone?apiKey=$IPGEOLOCATION_API_KEY&lat=40.7128&long=-74.0060'"
        },
        {
          "path": "/astronomy?apiKey={key}&lat={lat}&long={lon}",
          "method": "GET",
          "desc": "Sunrise, sunset, moonrise, moonset for coordinates",
          "example": "curl 'https://api.ipgeolocation.io/astronomy?apiKey=$IPGEOLOCATION_API_KEY&lat=33.4484&long=-112.0740'"
        }
      ]
    },
    {
      "name": "REST Countries",
      "base_url": "https://restcountries.com/v3.1",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, open access",
      "key_env_var": null,
      "docs_url": "https://restcountries.com/",
      "endpoints": [
        {
          "path": "/name/{name}",
          "method": "GET",
          "desc": "Search countries by name (common or official)",
          "example": "curl 'https://restcountries.com/v3.1/name/germany'"
        },
        {
          "path": "/alpha/{code}",
          "method": "GET",
          "desc": "Get country by ISO 3166-1 alpha-2 or alpha-3 code",
          "example": "curl 'https://restcountries.com/v3.1/alpha/US'"
        },
        {
          "path": "/region/{region}",
          "method": "GET",
          "desc": "List all countries in a region (africa, americas, asia, europe, oceania)",
          "example": "curl 'https://restcountries.com/v3.1/region/europe'"
        }
      ]
    },
    {
      "name": "GeoNames",
      "base_url": "http://api.geonames.org",
      "auth": "apiKey",
      "auth_param": "username",
      "auth_location": "query",
      "free_tier": "Free with username registration, 20,000 credits/day, 1,000/hour",
      "key_env_var": "GEONAMES_USERNAME",
      "docs_url": "https://www.geonames.org/export/web-services.html",
      "endpoints": [
        {
          "path": "/searchJSON?q={query}&maxRows=10&username={key}",
          "method": "GET",
          "desc": "Search for place names worldwide",
          "example": "curl 'http://api.geonames.org/searchJSON?q=London&maxRows=10&username=$GEONAMES_USERNAME'"
        },
        {
          "path": "/findNearbyPlaceNameJSON?lat={lat}&lng={lon}&username={key}",
          "method": "GET",
          "desc": "Find nearby places for given coordinates",
          "example": "curl 'http://api.geonames.org/findNearbyPlaceNameJSON?lat=47.3&lng=9.0&username=$GEONAMES_USERNAME'"
        },
        {
          "path": "/timezoneJSON?lat={lat}&lng={lon}&username={key}",
          "method": "GET",
          "desc": "Get timezone information for coordinates",
          "example": "curl 'http://api.geonames.org/timezoneJSON?lat=48.8567&lng=2.3508&username=$GEONAMES_USERNAME'"
        }
      ]
    },
    {
      "name": "Mapbox",
      "base_url": "https://api.mapbox.com",
      "auth": "apiKey",
      "auth_param": "access_token",
      "auth_location": "query",
      "free_tier": "100,000 requests/month for geocoding, 50,000 for directions",
      "key_env_var": "MAPBOX_ACCESS_TOKEN",
      "docs_url": "https://docs.mapbox.com/api/",
      "endpoints": [
        {
          "path": "/geocoding/v5/mapbox.places/{query}.json?access_token={key}",
          "method": "GET",
          "desc": "Forward geocode a place name or address to coordinates",
          "example": "curl 'https://api.mapbox.com/geocoding/v5/mapbox.places/Los+Angeles.json?access_token=$MAPBOX_ACCESS_TOKEN'"
        },
        {
          "path": "/geocoding/v5/mapbox.places/{lon},{lat}.json?access_token={key}",
          "method": "GET",
          "desc": "Reverse geocode coordinates to a place name",
          "example": "curl 'https://api.mapbox.com/geocoding/v5/mapbox.places/-118.2437,34.0522.json?access_token=$MAPBOX_ACCESS_TOKEN'"
        },
        {
          "path": "/directions/v5/mapbox/driving/{lon1},{lat1};{lon2},{lat2}?access_token={key}",
          "method": "GET",
          "desc": "Get driving directions between two points",
          "example": "curl 'https://api.mapbox.com/directions/v5/mapbox/driving/-73.9857,40.7484;-118.2437,34.0522?access_token=$MAPBOX_ACCESS_TOKEN'"
        }
      ]
    },
    {
      "name": "What3Words",
      "base_url": "https://api.what3words.com/v3",
      "auth": "apiKey",
      "auth_param": "key",
      "auth_location": "query",
      "free_tier": "Free tier available for evaluation and small-scale use",
      "key_env_var": "WHAT3WORDS_API_KEY",
      "docs_url": "https://developer.what3words.com/public-api",
      "endpoints": [
        {
          "path": "/convert-to-coordinates?words={3words}&key={key}",
          "method": "GET",
          "desc": "Convert a 3 word address to coordinates",
          "example": "curl 'https://api.what3words.com/v3/convert-to-coordinates?words=filled.count.soap&key=$WHAT3WORDS_API_KEY'"
        },
        {
          "path": "/convert-to-3wa?coordinates={lat},{lon}&key={key}",
          "method": "GET",
          "desc": "Convert coordinates to a 3 word address",
          "example": "curl 'https://api.what3words.com/v3/convert-to-3wa?coordinates=51.5074,-0.1278&key=$WHAT3WORDS_API_KEY'"
        },
        {
          "path": "/autosuggest?input={partial}&key={key}",
          "method": "GET",
          "desc": "Autocomplete partial 3 word addresses",
          "example": "curl 'https://api.what3words.com/v3/autosuggest?input=filled.count.so&key=$WHAT3WORDS_API_KEY'"
        }
      ]
    },
    {
      "name": "Zippopotam.us",
      "base_url": "https://api.zippopotam.us",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, free and open",
      "key_env_var": null,
      "docs_url": "https://www.zippopotam.us/",
      "endpoints": [
        {
          "path": "/{country}/{postal_code}",
          "method": "GET",
          "desc": "Get place information for a postal code in a given country",
          "example": "curl 'https://api.zippopotam.us/us/90210'"
        },
        {
          "path": "/{country}/{state}/{city}",
          "method": "GET",
          "desc": "Get postal codes for a city in a given country and state",
          "example": "curl 'https://api.zippopotam.us/us/ca/los+angeles'"
        }
      ]
    },
    {
      "name": "TimeZoneDB",
      "base_url": "http://api.timezonedb.com/v2.1",
      "auth": "apiKey",
      "auth_param": "key",
      "auth_location": "query",
      "free_tier": "Free tier with 1 request/second",
      "key_env_var": "TIMEZONEDB_API_KEY",
      "docs_url": "https://timezonedb.com/api",
      "endpoints": [
        {
          "path": "/get-time-zone?key={key}&format=json&by=position&lat={lat}&lng={lon}",
          "method": "GET",
          "desc": "Get timezone for coordinates including current local time",
          "example": "curl 'http://api.timezonedb.com/v2.1/get-time-zone?key=$TIMEZONEDB_API_KEY&format=json&by=position&lat=40.7128&lng=-74.0060'"
        },
        {
          "path": "/get-time-zone?key={key}&format=json&by=zone&zone={timezone}",
          "method": "GET",
          "desc": "Get current time and UTC offset for a named timezone",
          "example": "curl 'http://api.timezonedb.com/v2.1/get-time-zone?key=$TIMEZONEDB_API_KEY&format=json&by=zone&zone=America/New_York'"
        },
        {
          "path": "/list-time-zone?key={key}&format=json",
          "method": "GET",
          "desc": "List all supported timezones",
          "example": "curl 'http://api.timezonedb.com/v2.1/list-time-zone?key=$TIMEZONEDB_API_KEY&format=json'"
        }
      ]
    },
    {
      "name": "CountryIS",
      "base_url": "https://api.country.is",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, rate limited",
      "key_env_var": null,
      "docs_url": "https://country.is/",
      "endpoints": [
        {
          "path": "/{ip}",
          "method": "GET",
          "desc": "Get the country for an IP address",
          "example": "curl 'https://api.country.is/8.8.8.8'"
        },
        {
          "path": "/",
          "method": "GET",
          "desc": "Get the country for the requesting IP address",
          "example": "curl 'https://api.country.is/'"
        }
      ]
    },
    {
      "name": "Abstract IP Geolocation",
      "base_url": "https://ipgeolocation.abstractapi.com/v1",
      "auth": "apiKey",
      "auth_param": "api_key",
      "auth_location": "query",
      "free_tier": "Free tier with 20,000 requests/month",
      "key_env_var": "ABSTRACT_GEOLOCATION_API_KEY",
      "docs_url": "https://docs.abstractapi.com/ip-geolocation",
      "endpoints": [
        {
          "path": "/?api_key={key}&ip_address={ip}",
          "method": "GET",
          "desc": "Full geolocation data for an IP including city, region, timezone, currency",
          "example": "curl 'https://ipgeolocation.abstractapi.com/v1/?api_key=$ABSTRACT_GEOLOCATION_API_KEY&ip_address=8.8.8.8'"
        },
        {
          "path": "/?api_key={key}",
          "method": "GET",
          "desc": "Geolocation data for the requesting IP address",
          "example": "curl 'https://ipgeolocation.abstractapi.com/v1/?api_key=$ABSTRACT_GEOLOCATION_API_KEY'"
        }
      ]
    },
    {
      "name": "Geoapify",
      "base_url": "https://api.geoapify.com/v1",
      "auth": "apiKey",
      "auth_param": "apiKey",
      "auth_location": "query",
      "free_tier": "Free tier with 3,000 requests/day",
      "key_env_var": "GEOAPIFY_API_KEY",
      "docs_url": "https://apidocs.geoapify.com/",
      "endpoints": [
        {
          "path": "/geocode/search?text={address}&apiKey={key}",
          "method": "GET",
          "desc": "Forward geocode an address to coordinates with structured results",
          "example": "curl 'https://api.geoapify.com/v1/geocode/search?text=38+Upper+Montagu+Street+London&apiKey=$GEOAPIFY_API_KEY'"
        },
        {
          "path": "/geocode/reverse?lat={lat}&lon={lon}&apiKey={key}",
          "method": "GET",
          "desc": "Reverse geocode coordinates to address",
          "example": "curl 'https://api.geoapify.com/v1/geocode/reverse?lat=51.5074&lon=-0.1278&apiKey=$GEOAPIFY_API_KEY'"
        },
        {
          "path": "/ipinfo?apiKey={key}&ip={ip}",
          "method": "GET",
          "desc": "IP geolocation with city, country, and ISP info",
          "example": "curl 'https://api.geoapify.com/v1/ipinfo?apiKey=$GEOAPIFY_API_KEY&ip=8.8.8.8'"
        }
      ]
    }
  ]
}