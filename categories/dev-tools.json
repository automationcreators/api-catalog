          "example": "curl -X POST 'https://ray.so/api/generate?title=example&theme=midnight&padding=32&language=python' -d 'print(\"hello world\")'"
        }
      ]
    },
    {
      "name": "DevDocs.io",
      "base_url": "https://devdocs.io",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required, unified documentation search for 400+ languages and frameworks",
      "key_env_var": null,
      "docs_url": "https://devdocs.io/about",
      "endpoints": [
        {
          "path": "/docs/{doc}/index.json",
          "method": "GET",
          "desc": "Get the documentation index for a specific language or framework",
          "example": "curl 'https://devdocs.io/docs/python~3.12/index.json'"
        },
        {
          "path": "/docs.json",
          "method": "GET",
          "desc": "List all available documentation sets",
          "example": "curl 'https://devdocs.io/docs.json'"
        }
      ]
    },
    {
      "name": "StackExchange API",
      "base_url": "https://api.stackexchange.com/2.3",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required for basic (300 requests/day), API key for 10,000/day",
      "key_env_var": null,
      "docs_url": "https://api.stackexchange.com/docs",
