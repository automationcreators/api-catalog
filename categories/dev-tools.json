          "desc": "Get question details with body by question ID",
          "example": "curl 'https://api.stackexchange.com/2.3/questions/11227809?site=stackoverflow&filter=withbody'"
        },
        {
          "path": "/questions/{id}/answers?order=desc&sort=votes&site=stackoverflow&filter=withbody",
          "method": "GET",
          "desc": "Get answers for a question, sorted by votes",
          "example": "curl 'https://api.stackexchange.com/2.3/questions/11227809/answers?order=desc&sort=votes&site=stackoverflow&filter=withbody'"
        }
      ]
    },
    {
      "name": "Snyk",
      "base_url": "https://api.snyk.io/v1",
      "auth": "bearer",
      "auth_param": "Authorization",
      "auth_location": "header",
      "free_tier": "Free tier for open source projects, 200 tests/month",
      "key_env_var": "SNYK_TOKEN",
      "docs_url": "https://snyk.docs.apiary.io/",
