        },
        {
          "path": "/test/pip/{package}/{version}",
          "method": "GET",
          "desc": "Test a Python package for known vulnerabilities",
          "example": "curl 'https://api.snyk.io/v1/test/pip/requests/2.28.0' -H 'Authorization: token $SNYK_TOKEN'"
        }
      ]
    },
    {
      "name": "OSV.dev",
      "base_url": "https://api.osv.dev/v1",
