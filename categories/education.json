    {
      "name": "PurgoMalum",
      "description": "Profanity filter for text content",
      "base_url": "https://www.purgomalum.com",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "No key required",
      "key_env_var": null,
      "docs_url": "https://www.purgomalum.com/",
      "tier": 3,
