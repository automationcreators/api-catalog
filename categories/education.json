      "base_url": "https://api.funtranslations.com",
      "auth": "none",
      "auth_param": null,
      "auth_location": null,
      "free_tier": "5 calls/hour free",
      "key_env_var": null,
      "docs_url": "https://funtranslations.com/api/",
      "tier": 3,
